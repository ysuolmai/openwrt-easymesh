From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: ysuolmai <ysuolmai@users.noreply.github.com>
Date: Thu, 11 Jun 2026 00:00:00 +0800
Subject: [PATCH] net: phy: mxl-gpy: add GPY211B phylink interface support

The SX 7981R128 2.5G copper port uses a MaxLinear GPY211B PHY behind
MT7531 port 5. The PHY host side switches between 2500base-X for 2.5G
links and SGMII for 10/100/1000 links.

Without declaring both host interfaces, phylink validates the port only
against the device-tree 2500base-X mode. That prunes the lower copper link
modes, so the port links with 2.5G peers but not with 10/100/1000 peers.

Backport the relevant upstream GPY21x possible_interfaces handling and wire
GPY211B into the in-band configuration hooks provided by the downstream 6.6
phylink backport.

--- a/drivers/net/phy/mxl-gpy.c
+++ b/drivers/net/phy/mxl-gpy.c
@@ -308,6 +308,14 @@ static int gpy_config_init(struct phy_de
 	return gpy_led_write(phydev);
 }
 
+static int gpy21x_config_init(struct phy_device *phydev)
+{
+	__set_bit(PHY_INTERFACE_MODE_2500BASEX, phydev->possible_interfaces);
+	__set_bit(PHY_INTERFACE_MODE_SGMII, phydev->possible_interfaces);
+
+	return gpy_config_init(phydev);
+}
+
 static int gpy_probe(struct phy_device *phydev)
 {
 	struct device *dev = &phydev->mdio.dev;
@@ -722,6 +730,27 @@ static int gpy_led_polarity_set(struct p
 	unreachable();
 }
 
+static unsigned int gpy_inband_caps(struct phy_device *phydev,
+				    phy_interface_t interface)
+{
+	switch (interface) {
+	case PHY_INTERFACE_MODE_SGMII:
+		return LINK_INBAND_DISABLE | LINK_INBAND_ENABLE;
+	case PHY_INTERFACE_MODE_2500BASEX:
+		return LINK_INBAND_DISABLE;
+	default:
+		return 0;
+	}
+}
+
+static int gpy_config_inband(struct phy_device *phydev, unsigned int modes)
+{
+	return phy_modify_mmd(phydev, MDIO_MMD_VEND1, VSPEC1_SGMII_CTRL,
+			      VSPEC1_SGMII_ANEN_ANRS,
+			      (modes == LINK_INBAND_DISABLE) ? 0 :
+			      VSPEC1_SGMII_ANEN_ANRS);
+}
+
 static struct phy_driver gpy_drivers[] = {
 	{
 		PHY_ID_MATCH_MODEL(PHY_ID_GPY2xx),
@@ -737,8 +766,10 @@ static struct phy_driver gpy_drivers[] =
 		.phy_id_mask	= PHY_ID_GPY21xB_MASK,
 		.name		= "Maxlinear Ethernet GPY211B",
 		.get_features	= genphy_c45_pma_read_abilities,
-		.config_init	= gpy_config_init,
+		.config_init	= gpy21x_config_init,
 		.probe		= gpy_probe,
+		.inband_caps	= gpy_inband_caps,
+		.config_inband	= gpy_config_inband,
 		.suspend	= genphy_suspend,
 		.resume		= genphy_resume,
 		.config_aneg	= gpy_config_aneg,
