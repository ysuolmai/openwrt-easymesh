#!/bin/sh

set -eu

log() {
	logger -t mesh-agent "$*"
}

uci_get() {
	uci -q get "$1" 2>/dev/null || printf '%s' "$2"
}

node_id() {
	local mac
	mac="$(cat /sys/class/net/br-lan/address 2>/dev/null || cat /sys/class/net/eth0/address 2>/dev/null || echo 02:00:00:00:00:01)"
	echo "ap-$(echo "$mac" | tr -d ':' | tail -c 7)"
}

model_name() {
	ubus call system board 2>/dev/null | jsonfilter -e '@.model' 2>/dev/null || echo unknown
}

lan_mac() {
	cat /sys/class/net/br-lan/address 2>/dev/null || cat /sys/class/net/eth0/address 2>/dev/null || echo 02:00:00:00:00:01
}

post_json() {
	local url="$1"
	local body="$2"
	curl -fsS -m 10 -H 'Content-Type: application/json' -d "$body" "$url"
}

register() {
	local ac="$1"
	local token="$2"
	local id
	local body

	id="$(node_id)"
	body="$(printf '{"id":"%s","mac":"%s","model":"%s","token":"%s"}' "$id" "$(lan_mac)" "$(model_name)" "$token")"
	post_json "$ac/register" "$body" || true
}

pull_config() {
	local ac="$1"
	local token="$2"
	local id
	local body

	id="$(node_id)"
	body="$(printf '{"id":"%s","token":"%s"}' "$id" "$token")"
	post_json "$ac/config" "$body"
}

apply_if_approved() {
	local cfg="$1"
	local approved

	approved="$(jsonfilter -s "$cfg" -e '@.approved' 2>/dev/null || echo false)"
	[ "$approved" = "true" ] || return 1

	printf '%s' "$cfg" > /etc/mesh-agent/config.json
	/usr/sbin/mesh-agent-apply /etc/mesh-agent/config.json
}

main() {
	local ac token interval cfg

	ac="$(uci_get mesh_agent.main.ac_url http://192.168.50.1/cgi-bin/mesh-ac)"
	token="$(uci_get mesh_agent.main.pairing_token '')"
	interval="$(uci_get mesh_agent.main.poll_interval 30)"

	while true; do
		register "$ac" "$token"
		cfg="$(pull_config "$ac" "$token" || true)"
		if [ -n "$cfg" ] && apply_if_approved "$cfg"; then
			log "applied AC config"
		else
			log "waiting for AC approval or config"
		fi
		sleep "$interval"
	done
}

main "$@"
