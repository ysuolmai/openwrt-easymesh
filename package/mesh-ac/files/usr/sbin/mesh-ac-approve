#!/bin/sh

set -eu

id="${1:-}"
[ -n "$id" ] || {
	echo "usage: mesh-ac-approve <node-id>" >&2
	exit 1
}

node="/etc/mesh-ac/nodes/$id.json"
[ -f "$node" ] || {
	echo "unknown node: $id" >&2
	exit 1
}

tmp="/tmp/mesh-ac-approve-$id.json"
sed 's/"approved":[ ]*false/"approved":true/' "$node" > "$tmp"
mv "$tmp" "$node"

echo "approved $id"
