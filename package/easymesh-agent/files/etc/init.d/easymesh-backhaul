#!/bin/sh /etc/rc.common

START=86
STOP=10
USE_PROCD=1

uci_get() {
	uci -q get "$1" 2>/dev/null || printf '%s' "$2"
}

wired_preferred_enabled() {
	local value

	if [ -f /etc/config/easymesh ]; then
		value="$(uci_get easymesh.main.wired_preferred 1)"
	else
		value="$(uci_get easymesh_agent.main.wired_preferred 1)"
	fi
	[ "$value" = "1" ]
}

start_service() {
	wired_preferred_enabled || return 0
	[ -x /usr/sbin/easymesh-backhaul-watchdog ] || return 0

	procd_open_instance
	procd_set_param command /usr/sbin/easymesh-backhaul-watchdog
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger easymesh
	procd_add_reload_trigger easymesh_agent
	procd_add_reload_trigger network
}

reload_service() {
	restart
}
