#!/bin/sh

/etc/init.d/umdns enable >/dev/null 2>&1 || true

if [ -f /etc/config/easymesh ]; then
	uci -q set easymesh_agent.main.enabled='0'
	uci -q commit easymesh_agent
	/etc/init.d/easymesh-agent disable >/dev/null 2>&1 || true
	/etc/init.d/easymesh-backhaul stop >/dev/null 2>&1 || true
	/etc/init.d/easymesh-backhaul disable >/dev/null 2>&1 || true
else
	if [ -f /usr/lib/easymesh/ath11k-nss.sh ]; then
		. /usr/lib/easymesh/ath11k-nss.sh
		ath11k_nss_set_offload 0 "managed AP default" || true
	fi
	/usr/sbin/easymesh-agent-apply --network-only >/dev/null 2>&1 || true
	/etc/init.d/easymesh-agent enable >/dev/null 2>&1 || true
	/etc/init.d/easymesh-backhaul enable >/dev/null 2>&1 || true
fi

exit 0
